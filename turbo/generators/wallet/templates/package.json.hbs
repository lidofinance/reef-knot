  "scripts": {
    "build": "yarn run -T tsdown && yarn run -T tsc --noEmit false --noEmitOnError false --emitDeclarationOnly --outDir dist || true",
    "dev": "yarn run -T tsdown --watch",
    "lint": "eslint --ext ts,tsx,js,mjs ."
  },
  "devDependencies": {
    "@reef-knot/types": "^4.0.0",
    "@reef-knot/wallets-helpers": "^2.1.1",
    "build-config": "*",
    "eslint-config-custom": "*"
  },
  "peerDependencies": {
    "wagmi": ">=2.14",
    "@reef-knot/types": "^4.0.0",
    "@reef-knot/wallets-helpers": "^2.0.2"
  }
